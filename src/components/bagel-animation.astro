<pre
  id="bagel"
  class="flex h-75 max-w-75 w-full select-none items-center justify-center overflow-hidden text-[0.25rem] leading-none">
</pre>

<script>
  const BAGEL_SPEED = 0.025; // lower = slower
  const WIDTH = 280;
  const HEIGHT = 160;
  const CHARS = ".,-bagelfund";

  let A = 1;
  let B = 1;

  const renderAsciiFrame = (preTag: HTMLPreElement) => {
    const b = Array(WIDTH * HEIGHT).fill(" ");
    const z = Array(WIDTH * HEIGHT).fill(0);

    A += 0.07 * BAGEL_SPEED;
    B += 0.03 * BAGEL_SPEED;

    const [cA, sA, cB, sB] = [
      Math.cos(A),
      Math.sin(A),
      Math.cos(B),
      Math.sin(B),
    ];

    // newline at the end of each row
    for (let k = WIDTH - 1; k < WIDTH * HEIGHT; k += WIDTH) {
      b[k] = "\n";
    }

    for (let j = 0; j < 2 * Math.PI; j += 0.07) {
      const ct = Math.cos(j);
      const st = Math.sin(j);

      for (let i = 0; i < 2 * Math.PI; i += 0.02) {
        const sp = Math.sin(i);
        const cp = Math.cos(i);
        const h = ct + 2;
        const D = 1 / (sp * h * sA + st * cA + 5);
        const t = sp * h * cA - st * sA;

        const x = Math.floor(
          WIDTH / 2 + (WIDTH / 4) * D * (cp * h * cB - t * sB),
        );
        const y = Math.floor(
          HEIGHT / 2 + (HEIGHT / 4) * D * (cp * h * sB + t * cB),
        );

        const o = x + WIDTH * y;
        const N = Math.floor(
          8 *
            ((st * sA - sp * ct * cA) * cB -
              sp * ct * sA -
              st * cA -
              cp * ct * sB),
        );

        if (y < HEIGHT && y >= 0 && x >= 0 && x < WIDTH && D > z[o]) {
          z[o] = D;
          b[o] = CHARS[Math.max(0, N)];
        }
      }
    }

    preTag.innerHTML = b.join("");
    requestAnimationFrame(() => renderAsciiFrame(preTag));
  };

  const preTag = document.querySelector<HTMLPreElement>("#bagel");

  if (preTag) {
    renderAsciiFrame(preTag);
  }
</script>
